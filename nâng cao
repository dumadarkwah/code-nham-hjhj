#include <iostream>
using namespace std;

int main() {
	int n, m;
    cin>>n;
    cin>>m;

    //Cấp phát bộ nhớ cho mảng 2 chiều
    int** arr = new int*[n];
    for (int i = 0; i < n; i++) {
        arr[i] = new int[m];
    }

    for (int i = 0; i < n; i++) {
        for (int j = 0; j < m; j++) {
            cin >> arr[i][j];
        }
    }

    for (int i = 0; i < n; i++) {
        int sum = 0; 
        for (int j = 0; j < m;j++) {
            sum += arr[i][j]; 
        }
cout<<sum<<endl;
    }
    for (int i = 0; i < n; i++) {
        delete [] arr[i];
    }
    delete[] arr;
    
    return 0;
}


