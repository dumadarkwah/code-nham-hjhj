#include <iostream>
using namespace std;

int giaiThua(int n) {
    if (n == 1 || n == 0){
        return 1;
    }
    return n*giaiThua(n - 1);
}

int main () {
    int a;
    cout<<"Tinh giai thua cua so: ";
    cin>>a;
    
    cout<<a<<"!"<<" = "<<giaiThua(a);
    
    return 0;
}

#include <iostream>
using namespace std;

int tong(int n) {
    if(n == 1) {
        return 1;
    }
    return n + tong(n - 1);
}

int main () {
    int a;
    cout<<"Tinh tong tu 1 cho den: ";
    cin>>a;
    
    cout<<"Tong tu 1 den "<<a<<" la: "<<tong(a);
    return 0;
}


//In ra dãy số Fibonacci

#include <iostream>
using namespace std;

int fibonacci(int n) {
    if ( n <= 1) {
        return n;
    }
    return fibonacci(n - 1) + fibonacci(n - 2);
}

int main () {
    int a;
    cout<<"Dãy fibonacci có số phần tử là: ";
    cin>>a;
    
    for (int i = 0; i <= a; i++) {
        cout<<fibonacci(i)<<" ";
    }
    return 0;
}


#include <iostream>

using namespace std;

void toUpper(string &s) {
    for (int i = 0; i < s.size(); i++) {
        if(s[i] >= 'a' && s[i] <= 'z') {
            s[i] -= 32;
        }
    }
}

int main() {
	string s;
	cin >> s;
	toUpper(s);
	cout << s;
	return 0;
}
